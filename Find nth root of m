class Solution:
    def nthRoot(self, n, m):
       # code here
       low=0
       high=m
       while low<=high:
           mid=(low+high)//2
           l=mid**n
           if l==m:
               return mid
           elif l>=m:
               high=mid-1
           else:
               low=mid+1
               
       return -1
       
       
